# Files Manager
function ranger {
	local IFS=$'\t\n'
	local tempfile="$(mktemp -t tmp.XXXXXX)"
	local ranger_cmd=(
		command
		ranger
		--cmd="map Q chain shell echo %d > "$tempfile"; quitall"
	)

	${ranger_cmd[@]} "$@"
	if [[ -f "$tempfile" ]] && [[ "$(cat -- "$tempfile")" != "$(echo -n `pwd`)" ]]; then
		cd -- "$(cat "$tempfile")" || return
	fi
	command rm -f -- "$tempfile" 2>/dev/null
}
alias rr='ranger'

# Remove Directory (default: node_modules)
clean-dir() {
  # 如果有参数，则使用参数作为待查找目录名，否则默认为 node_modules，（自动排除 nested）
  local target="${1:-node_modules}"

  echo "🔍 使用 fd 扫描目录：${target}..."

  # 1) 用 fd 搜索目标目录
  # 2) 过滤 nested：路径中出现超过 1 次 target 的都是嵌套目录
  local modules
  modules=$(
    fd -HI -t d "${target}" . \
      | grep -vE "${target}/.*/${target}" \
      | sed 's|^\./||'
  )

  if [[ -z "$modules" ]]; then
    echo "❌ 未找到目标目录：${target}"
    return
  fi

  echo "📦 正在统计大小..."

  # du 并行统计大小
  local list
  list=$(echo "$modules" \
    | xargs -P 8 -I{} sh -c 'du -sh "{}" 2>/dev/null' \
    | sort -hr)

  echo "📂 找到的 ${target}："
  echo "$list"
  echo

  echo "👇 请选择要删除的条目（TAB 多选，可输入路径片段过滤）"

  local selected
  selected=$(echo "$list" \
    | fzf -m \
          --preview 'du -sh {+2}' \
          --preview-window=right:30% \
          --bind "change:reload(echo \"$list\" | grep -i -- {q} || true)" \
          --height=80% \
          --reverse \
          --prompt="Select directories to delete > " \
    ) || return

  echo
  echo "🗑️ 即将删除："
  echo "$selected"
  echo

  read "?确认删除? (y/N) " confirm
  if [[ "$confirm" != "y" ]]; then
    echo "❌ 已取消。"
    return
  fi

  # 并行删除
  echo "$selected" \
    | awk '{print $2}' \
    | xargs -P 8 -I{} rm -rf "{}"

  echo "✅ 已删除目标目录：${target}"
}

